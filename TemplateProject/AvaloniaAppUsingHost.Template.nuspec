<?xml version="1.0"?>
<package >
  <metadata>
    <id>AvaloniaAppUsingHost.Template</id>
    <version>3.2.0</version>    
    <authors>Jeppe Roi Kristensen</authors>
    <owners>Jeppe Roi Kristensen</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <description>A .NET solution template for Avalonia applications using Host.</description>
    <summary>Avalonia application template using Microsoft.Extensions.Hosting and MVVM pattern.</summary>    
    <tags>avalonia template mvvm desktop</tags>
    <repository type="git" url="https://github.com/jeppevammenkristensen/AvaloniaAppUsingHost" />
    <releaseNotes>
      - Rewrite of styles
      - Bumped versions to 12.0.2
      - Fixed issue where .template.config folder was included
    </releaseNotes>
    <readme>docs/readme.md</readme>
    <packageTypes>
      <packageType name="Template" />
    </packageTypes>
  </metadata>
  <files>
    <file src="**\*" target="content" exclude="**\bin\**;**\obj\**;**\.idea\*;**\.vs\**;*sln.DotSettings*;docs\**" />
    <file src="docs\readme.md" target="docs\" />
  </files>
</package>
